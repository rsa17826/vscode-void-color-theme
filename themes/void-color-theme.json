  "tokenColors": [
    // ─── Punctuation & Base ───────────────────────────────────────────────────
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#9070c8" }
    },
    {
      "name": "Punctuation Delimiter",
      "scope": ["punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#605090" }
    },

    // ─── Comments ─────────────────────────────────────────────────────────────
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#9070c8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc Comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.double-slash.documentation"
      ],
      "settings": {
        "foreground": "#7a68a8",
        "fontStyle": "italic"
      }
    },

    // ─── Keywords ─────────────────────────────────────────────────────────────
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.delete",
        "storage.modifier"
      ],
      "settings": { "foreground": "#cc55ff", "fontStyle": "italic" }
    },
    {
      "name": "Import / Export keywords",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": { "foreground": "#cc88ff", "fontStyle": "italic" }
    },
    {
      "name": "Storage / Type keywords",
      "scope": [
        "storage.type",
        "storage.type.function",
        "storage.type.class"
      ],
      "settings": { "foreground": "#cc55ff", "fontStyle": "italic" }
    },
    {
      "name": "Return / Await / Yield",
      "scope": [
        "keyword.control.return",
        "keyword.control.flow.return",
        "keyword.control.await",
        "keyword.control.flow.await",
        "keyword.control.yield"
      ],
      "settings": { "foreground": "#f040ff", "fontStyle": "italic" }
    },

    // ─── Operators ────────────────────────────────────────────────────────────
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation.operator"],
      "settings": { "foreground": "#8870b0" }
    },
    {
      "name": "Logical Operators",
      "scope": [
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.relational"
      ],
      "settings": { "foreground": "#a888cc" }
    },
    {
      "name": "Arrow",
      "scope": [
        "storage.type.function.arrow",
        "keyword.operator.arrow"
      ],
      "settings": { "foreground": "#cc88ff" }
    },

    // ─── Variables ────────────────────────────────────────────────────────────
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#ddd4ff" }
    },
    {
      "name": "Variable Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property"
      ],
      "settings": { "foreground": "#d0c4ff" }
    },
    {
      "name": "Special variables (this/self/super)",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": { "foreground": "#cc88ff", "fontStyle": "italic" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#ccc0ff" }
    },

    // ─── Functions ────────────────────────────────────────────────────────────
    {
      "name": "Function names",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function"
      ],
      "settings": { "foreground": "#7c6fff" }
    },
    {
      "name": "Function calls",
      "scope": ["meta.function-call entity.name.function"],
      "settings": { "foreground": "#9080ff" }
    },
    {
      "name": "Built-in functions",
      "scope": ["support.function.builtin"],
      "settings": { "foreground": "#00f5d0" }
    },

    // ─── Types & Classes ──────────────────────────────────────────────────────
    {
      "name": "Type / Class names",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": { "foreground": "#e840ff" }
    },
    {
      "name": "Interface names",
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#f060ff", "fontStyle": "italic" }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "entity.name.type.alias",
        "support.type"
      ],
      "settings": { "foreground": "#da40ff" }
    },
    {
      "name": "Generics / Type parameters",
      "scope": ["entity.name.type.parameter", "meta.type.parameters"],
      "settings": { "foreground": "#df50ff" }
    },

    // ─── Strings ──────────────────────────────────────────────────────────────
    {
      "name": "Strings",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#ff70a8" }
    },
    {
      "name": "Template literals",
      "scope": ["string.template", "string.interpolated"],
      "settings": { "foreground": "#ff88bc" }
    },
    {
      "name": "Template literal embedded",
      "scope": [
        "meta.embedded.expression",
        "punctuation.definition.template-expression"
      ],
      "settings": { "foreground": "#cc88ff" }
    },
    {
      "name": "Escape sequences",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#ff40a0" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#ff5090" }
    },
    {
      "name": "Regex special chars",
      "scope": [
        "keyword.operator.quantifier.regexp",
        "punctuation.definition.character-class.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": { "foreground": "#ff3070" }
    },

    // ─── Numbers, Booleans, Constants ─────────────────────────────────────────
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#ff80c8" }
    },
    {
      "name": "Booleans & null/undefined",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan",
        "constant.language.infinity"
      ],
      "settings": { "foreground": "#cc88ff", "fontStyle": "italic" }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "variable.other.constant",
        "entity.name.constant"
      ],
      "settings": { "foreground": "#cc88ff" }
    },

    // ─── Properties & Members ─────────────────────────────────────────────────
    {
      "name": "Object keys / properties",
      "scope": [
        "meta.object-literal.key",
        "support.type.property-name",
        "entity.name.tag.yaml"
      ],
      "settings": { "foreground": "#50c8ff" }
    },
    {
      "name": "Member access",
      "scope": ["variable.other.member", "variable.other.object"],
      "settings": { "foreground": "#ccc0ff" }
    },

    // ─── Tags (HTML/JSX) ──────────────────────────────────────────────────────
    {
      "name": "HTML Tags",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#7c6fff" }
    },
    {
      "name": "HTML attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#30c8ff", "fontStyle": "italic" }
    },
    {
      "name": "HTML attribute values",
      "scope": ["meta.attribute string"],
      "settings": { "foreground": "#ff70a8" }
    },
    {
      "name": "JSX component tags",
      "scope": ["support.class.component", "entity.name.tag.js.jsx"],
      "settings": { "foreground": "#e840ff" }
    },

    // ─── CSS ──────────────────────────────────────────────────────────────────
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.name.tag.css"
      ],
      "settings": { "foreground": "#cc88ff" }
    },
    {
      "name": "CSS Properties",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name"
      ],
      "settings": { "foreground": "#30c8ff" }
    },
    {
      "name": "CSS Values",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value"
      ],
      "settings": { "foreground": "#ff70a8" }
    },
    {
      "name": "CSS Units",
      "scope": ["keyword.other.unit.css"],
      "settings": { "foreground": "#ff80c8" }
    },
    {
      "name": "CSS Colors / Variables",
      "scope": [
        "support.constant.color",
        "variable.css",
        "variable.argument.css"
      ],
      "settings": { "foreground": "#00f5d0" }
    },
    {
      "name": "CSS at-rules",
      "scope": [
        "keyword.control.at-rule.css",
        "keyword.control.at-rule"
      ],
      "settings": { "foreground": "#cc55ff", "fontStyle": "italic" }
    },

    // ─── Markdown ─────────────────────────────────────────────────────────────
    {
      "name": "Markdown Headings",
      "scope": ["entity.name.section.markdown", "markup.heading"],
      "settings": { "foreground": "#cc88ff", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#e0d0ff", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#d0c0f8", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.raw.block"],
      "settings": { "foreground": "#00f5d0" }
    },
    {
      "name": "Markdown Links",
      "scope": ["markup.underline.link", "meta.link"],
      "settings": { "foreground": "#a050ff" }
    },
    {
      "name": "Markdown Blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#9070c8", "fontStyle": "italic" }
    },
    {
      "name": "Markdown List bullet",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#9940e0" }
    },

    // ─── JSON ─────────────────────────────────────────────────────────────────
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#50c8ff" }
    },
    {
      "name": "JSON strings",
      "scope": ["string.quoted.double.json"],
      "settings": { "foreground": "#ff70a8" }
    },

    // ─── Decorators / Annotations ─────────────────────────────────────────────
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#f0b8d080", "fontStyle": "italic" }
    },
    {
      "name": "Decorator names",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator entity.name.function"
      ],
      "settings": { "foreground": "#ff70a8", "fontStyle": "italic" }
    },

    // ─── Module / Imports ─────────────────────────────────────────────────────
    {
      "name": "Module names",
      "scope": ["entity.name.module", "support.module"],
      "settings": { "foreground": "#b880ff" }
    },

    // ─── Errors & Issues ──────────────────────────────────────────────────────
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": {
        "foreground": "#ff4d9f",
        "fontStyle": "strikethrough"
      }
    }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#e840ff",
    "namespace.declaration": {
      "foreground": "#e840ff",
      "italic": true
    },
    "class": "#e840ff",
    "class.declaration": { "foreground": "#e840ff", "bold": false },
    "interface": { "foreground": "#f060ff", "italic": true },
    "typeParameter": "#df50ff",
    "enum": "#e840ff",
    "enumMember": { "foreground": "#cc88ff", "italic": true },
    "struct": "#da40ff",
    "type": "#da40ff",
    "function": "#7c6fff",
    "function.declaration": {
      "foreground": "#7c6fff",
      "bold": false
    },
    "method": "#9888ff",
    "method.declaration": { "foreground": "#9888ff" },
    "property": "#50c8ff",
    "property.declaration": { "foreground": "#50c8ff" },
    "variable": "#ddd4ff",
    "variable.readonly": { "foreground": "#cc88ff", "italic": true },
    "parameter": "#ccc0ff",
    "string": "#ff70a8",
    "number": "#ff80c8",
    "keyword": { "foreground": "#cc55ff", "italic": true },
    "decorator": { "foreground": "#ff70a8", "italic": true },
    "macro": "#00f5d0",
    "selfKeyword": { "foreground": "#cc88ff", "italic": true },
    "lifetime": { "foreground": "#00f5d0", "italic": true }
  }
}
