    "toolbar.activeBackground": "#2a1f4060",

    // ─── Widgets ─────────────────────────────────────────────────────────────
    "walkThrough.embeddedEditorBackground": "#0d0a18",
    "welcomePage.background": "#0b0914",
    "welcomePage.tileBackground": "#0f0c1e",
    "welcomePage.tileHoverBackground": "#150f28",
    "welcomePage.tileBorder": "#2e2045",
    "welcomePage.progress.background": "#1e1830",
    "welcomePage.progress.foreground": "#9940e0"
