    "terminal.selectionBackground": "#3d286060",
    "terminal.ansiBrightBlack": "#6a5890",
    "terminal.ansiBlack": "#1e1830",
    "terminal.ansiBrightRed": "#ff60b0",
    "terminal.ansiRed": "#ff4d9f",
    "terminal.ansiBrightGreen": "#40f0b0",
    "terminal.ansiGreen": "#00e8a8",
    "terminal.ansiBrightYellow": "#ffe040",
    "terminal.ansiYellow": "#ffcc00",
    "terminal.ansiBrightBlue": "#60d8ff",
    "terminal.ansiBlue": "#2090e8",
    "terminal.ansiBrightMagenta": "#dd80ff",
    "terminal.ansiMagenta": "#cc88ff",
    "terminal.ansiBrightCyan": "#60f8e8",
    "terminal.ansiCyan": "#00f5d0",
    "terminal.ansiBrightWhite": "#f0e8ff",
    "terminal.ansiWhite": "#e2d8ff",
